# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/cocointerview?schema=public
ADMIN_API_SECRET=
LEGACY_BOOTSTRAP_PASSWORD=

# Fixed cloud runtime
ASR_MODE=doubao
LLM_PROVIDER=aihubmix
AIHUBMIX_API_KEY=
AIHUBMIX_MODEL=gemini-3-flash-preview
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
AIHUBMIX_PATH=/chat/completions
MEETING_AUDIO_STORAGE_ROOT=/data/meetings
MEETING_ATTACHMENT_STORAGE_ROOT=/data/meeting-attachments

# Doubao ASR
DOUBAO_ASR_APP_ID=
DOUBAO_ASR_ACCESS_TOKEN=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
ASR_PROXY_SESSION_SECRET=
ASR_PROXY_PUBLIC_BASE_URL=https://api.coco-interview.example.com
ASR_PROXY_HEALTH_PATH=/asr-proxy/healthz
ASR_PROXY_WS_PATH=/ws/asr
