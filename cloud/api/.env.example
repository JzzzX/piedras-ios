# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/piedras?schema=public
ADMIN_API_SECRET=
LEGACY_BOOTSTRAP_PASSWORD=

# Fixed cloud runtime
ASR_MODE=doubao
OPENAI_API_KEY=your_aihubmix_or_openai_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://aihubmix.com/v1
OPENAI_PATH=/chat/completions

# Doubao ASR
DOUBAO_ASR_APP_ID=
DOUBAO_ASR_ACCESS_TOKEN=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
ASR_PROXY_SESSION_SECRET=
ASR_PROXY_PUBLIC_BASE_URL=https://your-asr-proxy.example.com

# Optional fallbacks
LLM_PROVIDER=openai
LLM_FALLBACKS=gemini,minimax
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-Text-01
