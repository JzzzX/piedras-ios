generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                    String                 @id @default(uuid())
  name                  String
  description           String                 @default("")
  icon                  String                 @default("folder")
  color                 String                 @default("#94a3b8")
  workflowMode          String                 @default("general")
  modeLabel             String                 @default("")
  sortOrder             Int                    @default(0)
  ownerUserId           String?                @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  meetings              Meeting[]
  collections           Collection[]
  assets                WorkspaceAsset[]
  customVocabularyTerms CustomVocabularyTerm[]
  globalChatSessions    GlobalChatSession[]
  ownerUser             User?                  @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  authUserId         String?       @unique
  passwordHash       String?
  displayName        String        @default("")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  workspaces         Workspace[]   @relation("WorkspaceOwner")
  authSessions       AuthSession[]
  redeemedInviteCodes InviteCode[] @relation("InviteCodeRedeemer")
}

model AuthSession {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model InviteCode {
  id               String    @id @default(uuid())
  code             String    @unique
  note             String    @default("")
  isRevoked        Boolean   @default(false)
  redeemedByUserId String?
  redeemedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  redeemedByUser User? @relation("InviteCodeRedeemer", fields: [redeemedByUserId], references: [id], onDelete: SetNull)

  @@index([isRevoked, redeemedAt])
}

model Meeting {
  id            String   @id @default(uuid())
  title         String   @default("")
  date          DateTime @default(now())
  status        String   @default("idle")
  duration      Int      @default(0)
  audioMimeType String?
  audioDuration Int?
  audioUpdatedAt DateTime?
  userNotes     String   @default("")
  enhancedNotes String   @default("")
  audioEnhancedNotes String @default("")
  audioEnhancedNotesStatus String @default("idle")
  audioEnhancedNotesError String @default("")
  audioEnhancedNotesUpdatedAt DateTime?
  audioEnhancedNotesProvider String?
  audioEnhancedNotesModel String?
  enhanceRecipeId String?
  roundLabel    String   @default("")
  interviewerName String @default("")
  recommendation String  @default("pending")
  handoffNote   String   @default("")
  speakers      String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  collectionId  String? @map("folderId")
  workspaceId   String

  segments     TranscriptSegment[]
  chatMessages ChatMessage[]
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String    @id @default(uuid())
  name        String
  description String    @default("")
  icon        String    @default("folder")
  color       String    @default("#94a3b8")
  handoffSummary String @default("")
  candidateStatus String @default("new")
  nextInterviewer String @default("")
  nextFocus   String    @default("")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspaceId String

  meetings  Meeting[]
  assets    WorkspaceAsset[]
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("Folder")
}

model WorkspaceAsset {
  id               String     @id @default(uuid())
  name             String
  originalName     String
  assetType        String
  mimeType         String
  fileSize         Int
  storageKey       String
  extractedText    String     @default("")
  extractionStatus String     @default("preview")
  extractionError  String     @default("")
  workspaceId      String
  collectionId     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, collectionId, updatedAt])
}

model TranscriptSegment {
  id        String  @id @default(uuid())
  speaker   String
  text      String
  startTime Float
  endTime   Float
  isFinal   Boolean @default(true)
  order     Int     @default(0)

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String  @id @default(uuid())
  role       String
  content    String
  timestamp  Float
  templateId String?

  meetingId String
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model PromptTemplate {
  id          String   @id @default(uuid())
  name        String
  command     String   @unique
  icon        String   @default("📝")
  description String
  prompt      String
  starterQuestion String @default("")
  surfaces    String   @default("both")
  category    String   @default("记录")
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomVocabularyTerm {
  id          String    @id @default(uuid())
  term        String
  scope       String
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([scope, workspaceId, term])
  @@index([scope, workspaceId])
}

model AsrVocabularySyncState {
  id                String   @id
  remoteVocabularyId String?
  contentHash       String   @default("")
  lastSyncedAt      DateTime?
  lastError         String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GlobalChatSession {
  id         String              @id @default(uuid())
  title      String
  scope      String
  filters    String              @default("{}")
  workspaceId String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  workspace Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  messages  GlobalChatMessage[]

  @@index([updatedAt])
  @@index([workspaceId])
}

model GlobalChatMessage {
  id         String            @id @default(uuid())
  role       String
  content    String
  timestamp  Float
  templateId String?
  sessionId  String

  session GlobalChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}
